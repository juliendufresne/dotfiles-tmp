# Configuration for the dev toolbox (see the Makefile).
#
# These variables are sourced by the Makefile. This file holds the shared,
# tracked defaults; copy any line you need to change into .env.local (which is
# gitignored) to override it on a per-machine basis.
#
# The Makefile already defines sensible defaults via `?=`, so every line below
# is commented out and serves as documentation.

# Name (tag) of the locally built dev toolbox image.
#DEV_TOOL_IMAGE=dotfiles-dev-tools

# Ubuntu release the dev toolbox image is based on.
#UBUNTU_VERSION=26.04

# shellcheck release installed in the dev toolbox image.
#SHELLCHECK_VERSION=0.11.0

# shellspec release installed in the dev toolbox image (shell test runner).
#SHELLSPEC_VERSION=0.28.1

# kcov release compiled from source in the dev toolbox image (shell coverage).
#KCOV_VERSION=43
