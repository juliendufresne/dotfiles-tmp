#!/usr/bin/env bash
set -euo pipefail

# ─── Bootstrap ────────────────────────────────────────────────────────────────

#--------------------------------------------------
# Function:
#   dotfiles::require_bash [<major>] [<minor>]
#
# Description:
#   Fails when the running bash is older than 4.2. The installer uses the
#   `[[ -v ]]` conditional (introduced in bash 4.2) throughout, so an older
#   shell would die with a cryptic syntax error partway through. macOS ships
#   bash 3.2 as /bin/bash, so check up front and fail with an actionable
#   message instead. The version defaults to the running shell; the arguments
#   exist so both branches can be exercised in tests. Reads only BASH_VERSINFO
#   and arithmetic, so it is itself 3.2-safe and must run before the first
#   `[[ -v ]]`.
#
# Arguments:
#   <major>  Running bash major version (default ${BASH_VERSINFO[0]})
#   <minor>  Running bash minor version (default ${BASH_VERSINFO[1]})
#
# Returns:
#   0 when the running bash is >= 4.2
#   1 (after printing guidance to stderr) when it is older
#
# Example:
#   dotfiles::require_bash
#--------------------------------------------------
dotfiles::require_bash() {
    local major="${1:-${BASH_VERSINFO[0]}}"
    local minor="${2:-${BASH_VERSINFO[1]}}"

    if (( major < 4 || ( major == 4 && minor < 2 ) ))
    then
        printf 'dotfiles: requires bash >= 4.2 (found %s).\n' "${BASH_VERSION}" >&2
        printf 'On macOS install a newer bash, e.g. brew install bash\n' >&2

        return 1
    fi
}
[[ -v TEST_FLAG ]] || readonly -f dotfiles::require_bash

dotfiles::require_bash

# ─── Functions ────────────────────────────────────────────────────────────────

#--------------------------------------------------
# Function:
#   dotfiles::usage
#
# Description:
#   Writes the command-line usage to stdout: the synopsis, the available
#   commands, how tool arguments narrow the run, the options and a few
#   examples.
#
# Arguments:
#   N/A
#
# Returns:
#   0 always
#
# Example:
#   dotfiles::usage
#--------------------------------------------------
dotfiles::usage() {
    cat <<'EOF'
Usage: dotfiles [OPTIONS] [COMMAND] [TOOL...]

Link (or unlink) configuration for the tools installed on this machine.
A tool's config is applied only when that tool is present.

Commands:
  install     Link config for installed tools (default)
  uninstall   Remove links previously created by install

Tools:
  Zero or more tool names (e.g. git). With none given every tool is
  processed; otherwise only the named ones.

Options:
  -n, --dry-run   Show what would change without changing anything
  -h, --help      Show this help and exit

Examples:
  dotfiles                       # install every detected tool
  dotfiles install git           # install only git
  dotfiles uninstall --dry-run   # preview removing every link
EOF
}
[[ -v TEST_FLAG ]] || readonly -f dotfiles::usage

#--------------------------------------------------
# Function:
#   dotfiles::run <command> [<tool>...]
#
# Description:
#   Runs tool installers found under libexec, handing each the given
#   lifecycle command. With no tool names, every executable installer runs
#   in lexical order; with tool names, only those run - an unknown name is
#   rejected before anything executes. Each installer is a standalone
#   executable that dispatches on the command itself (install/uninstall),
#   so both lifecycles share this one discovery loop. Announces a dry run
#   up front (reading DOTFILES_DRY_RUN, which the installers also honor).
#   Reads DOTFILES_ROOT to locate the installers, and executes each one
#   (which may modify the home directory). Each installer prints its own
#   stage header and per-action detail; this loop adds no output of its
#   own beyond a "nothing to do" notice when no installer is dispatched
#   and the dry-run banner.
#
# Arguments:
#   <command>  Lifecycle command forwarded to every installer
#              (install or uninstall)
#   <tool>...  Optional installer names to restrict the run to
#
# Returns:
#   0 when every dispatched installer succeeds
#   2 when a named tool has no installer
#   N propagated from the first installer that fails
#
# Example:
#   dotfiles::run install git
#--------------------------------------------------
dotfiles::run() {
    local command
    local installer
    local installer_dir
    local -a installers
    local tool

    command="$1"
    shift
    installer_dir="${DOTFILES_ROOT}/libexec"
    installers=()

    if (( $# > 0 ))
    then
        for tool in "$@"
        do
            if [[ ! -x "${installer_dir}/${tool}" ]]
            then
                output::fatal "dotfiles: unknown tool: ${tool}"

                return 2
            fi

            installers+=( "${installer_dir}/${tool}" )
        done
    else
        for installer in "${installer_dir}"/*
        do
            [[ -x "${installer}" ]] || continue

            installers+=( "${installer}" )
        done
    fi

    if (( ${#installers[@]} == 0 ))
    then
        output::notice 'nothing to do'

        return 0
    fi

    if [[ -n "${DOTFILES_DRY_RUN:-}" ]]
    then
        output::notice 'dry run - no changes will be made'
    fi

    for installer in "${installers[@]+"${installers[@]}"}"
    do
        "${installer}" "${command}" || return $?
    done
}
[[ -v TEST_FLAG ]] || readonly -f dotfiles::run

# ─── Main ─────────────────────────────────────────────────────────────────────

#--------------------------------------------------
# Function:
#   dotfiles::main [OPTIONS] [<command>] [<tool>...]
#
# Description:
#   Entry point. Parses options and positional arguments, then dispatches
#   the requested lifecycle command (defaulting to install) to the
#   selected installers. --help prints usage and exits; --dry-run exports
#   DOTFILES_DRY_RUN so both this process and the installer subprocesses
#   run without writing. Unknown options are rejected with usage on
#   stderr.
#
# Arguments:
#   -n, --dry-run  Describe changes without making them
#   -h, --help     Print usage and return 0
#   <command>      install (default) or uninstall
#   <tool>...      Optional installer names to restrict the run to
#
# Returns:
#   0 on success, or after printing help
#   2 on an unknown option
#   N propagated from the dispatched command
#
# Example:
#   dotfiles::main install git
#--------------------------------------------------
dotfiles::main() {
    local arg
    local command
    local -a tools

    command='install'
    tools=()

    while (( $# > 0 ))
    do
        arg="$1"

        case "${arg}" in
            -h | --help)
                dotfiles::usage

                return 0
                ;;
            -n | --dry-run)
                DOTFILES_DRY_RUN=1
                export DOTFILES_DRY_RUN
                ;;
            --)
                shift

                break
                ;;
            -*)
                output::fatal "dotfiles: unknown option: ${arg}"
                dotfiles::usage >&2

                return 2
                ;;
            install | uninstall)
                command="${arg}"
                ;;
            *)
                tools+=( "${arg}" )
                ;;
        esac

        shift
    done

    # Anything after `--` is taken literally as a tool name.
    while (( $# > 0 ))
    do
        tools+=( "$1" )

        shift
    done

    dotfiles::run "${command}" "${tools[@]+"${tools[@]}"}"
}
[[ -v TEST_FLAG ]] || readonly -f dotfiles::main

# ─── Constants / globals ──────────────────────────────────────────────────────

DOTFILES_ROOT="$( cd "$( dirname "${BASH_SOURCE[0]}" )/.." && pwd )"
[[ -v TEST_FLAG ]] || readonly DOTFILES_ROOT

# ─── Imports ──────────────────────────────────────────────────────────────────

# shellcheck source=../lib/output.sh
source "${DOTFILES_ROOT}/lib/output.sh"

# ─── Execute ──────────────────────────────────────────────────────────────────

[[ "${BASH_SOURCE[0]}" != "$0" ]] || dotfiles::main "$@"
